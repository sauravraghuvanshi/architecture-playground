{
  "name": "architecture-playground",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive multi-cloud architecture diagram editor — drag-and-drop Azure/AWS/GCP icons, animated request sequences, and PNG/JSON/GIF export.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/build-cloud-icon-manifest.mjs && node scripts/bundle-gifenc-worker.mjs",
    "build": "next build",
    "postbuild": "node scripts/postbuild.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "build:icon-manifest": "node scripts/build-cloud-icon-manifest.mjs",
    "test:playground": "node --test scripts/test-playground.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "geist": "^1.7.0",
    "gifenc": "^1.0.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.575.0",
    "motion": "^12.38.0",
    "next": "^16.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "svgo": "^4.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
