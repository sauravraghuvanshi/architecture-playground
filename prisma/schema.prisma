// Architecture Playground — Prisma Schema
// Dev: SQLite · Prod: PostgreSQL (swap datasource provider + URL)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (NextAuth.js / Auth.js) ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  projects      Project[]
  diagrams      Diagram[]
  comments      Comment[]
  memberships   Membership[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Projects & Diagrams ──────────────────────────────────────────────

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagrams    Diagram[]
  archived    Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model Diagram {
  id          String           @id @default(cuid())
  name        String
  description String?
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The current graph state (JSON blob)
  graphJson   String           @default("{\"nodes\":[],\"edges\":[]}")
  thumbnail   String?          // base64 PNG thumbnail

  versions    DiagramVersion[]
  shares      ShareLink[]
  comments    Comment[]
  archived    Boolean          @default(false)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([projectId])
}

model DiagramVersion {
  id         String   @id @default(cuid())
  diagramId  String
  diagram    Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  version    Int
  label      String?  // e.g. "v1.0 — initial design"
  graphJson  String
  createdAt  DateTime @default(now())

  @@unique([diagramId, version])
  @@index([diagramId])
}

model ShareLink {
  id         String   @id @default(cuid())
  diagramId  String
  diagram    Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  token      String   @unique @default(cuid())
  permission String   @default("view") // "view" | "edit"
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([diagramId])
}

// ─── Comments (Phase 7) ───────────────────────────────────────────────

model Comment {
  id          String   @id @default(cuid())
  diagramId   String
  diagram     Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body        String
  // Anchor: optional nodeId / edgeId, or a free-floating canvas pin (x,y)
  nodeId      String?
  edgeId      String?
  pinX        Float?
  pinY        Float?
  resolved    Boolean  @default(false)
  parentId    String?  // for threaded replies
  parent      Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([diagramId])
  @@index([authorId])
}

// ─── Organizations & Membership (Phase 8) ─────────────────────────────

model Organization {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  // Branding
  logoUrl      String?
  accentColor  String?      // hex
  // Optional Stripe customer id for billing
  stripeCustomerId String?

  members      Membership[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("VIEWER") // OWNER | ADMIN | EDITOR | COMMENTER | VIEWER

  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ─── Audit log (Phase 8) ──────────────────────────────────────────────

model AuditLog {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  action          String        // e.g. "diagram.create"
  resourceType    String?       // e.g. "Diagram"
  resourceId      String?
  metadata        String?       // free-form JSON string
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

// ─── API keys (Phase 8) ───────────────────────────────────────────────

model ApiKey {
  id              String        @id @default(cuid())
  // Stored as a SHA-256 hex hash; the plaintext token is only shown once at creation.
  hashedKey       String        @unique
  prefix          String        // e.g. "ap_live_xxx" first 12 chars for identification in lists
  name            String
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  scopes          String        @default("read,write")
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([organizationId])
}
