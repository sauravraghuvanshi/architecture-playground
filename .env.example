# Public site URL used for canonical metadata (set per environment)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Application Insights for browser-side telemetry
# NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=

# Auth.js / NextAuth
AUTH_SECRET=  # Generate with: npx auth secret
GITHUB_ID=    # GitHub OAuth App → Client ID
GITHUB_SECRET= # GitHub OAuth App → Client Secret

# Database (SQLite for dev; swap to PostgreSQL for prod)
DATABASE_URL="file:./dev.db"
